# Server Configuration
PORT=3000
NODE_ENV=development

# Admin API Key (generate a secure random string)
ADMIN_KEY=your-secure-admin-key-here

# VK OAuth (https://vk.com/apps?act=manage)
VK_CLIENT_ID=your-vk-client-id
VK_CLIENT_SECRET=your-vk-client-secret
VK_REDIRECT_URI=http://localhost:3000/api/import/oauth/vk/callback

# Spotify OAuth (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/import/oauth/spotify/callback

# Yandex Music OAuth (https://oauth.yandex.ru/)
YANDEX_CLIENT_ID=your-yandex-client-id
YANDEX_CLIENT_SECRET=your-yandex-client-secret
YANDEX_REDIRECT_URI=http://localhost:3000/api/import/oauth/yandex/callback
